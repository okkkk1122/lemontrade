<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo-link">
      <img src="/logo.png" alt="<%= siteName %>" width="48" height="48" />
      <span><%= siteName %><% if (locale !== 'en') { %><small class="brand-en" lang="en"> <%= siteNameEn %></small><% } %></span>
    </a>
    <button class="hamburger" id="nav-toggle" aria-label="<%= t('nav.home') %>">☰</button>
    <nav class="nav-main" id="nav-main">
      <% headerMenu.forEach(function(item) {
        const path = item.link.split('?')[0];
        const active = currentPath === path || (path !== '/' && currentPath.startsWith(path));
      %>
        <a href="<%= item.link %>" class="<%= active ? 'active' : '' %>" <%= item.openNewTab ? 'target="_blank" rel="noopener"' : '' %>><%= item.title %></a>
      <% }); %>
      <% if (isLoggedIn) { %>
        <a href="/signals/live" class="<%= currentPath.startsWith('/signals') ? 'active' : '' %>"><%= t('nav.liveSignals') %></a>
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>"><%= t('nav.dashboard') %></a>
      <% } %>
    </nav>
    <div class="header-actions">
      <%- include('locale-switcher') %>
      <div class="theme-switcher">
        <button type="button" data-theme-set="light"><%= t('theme.light') %></button>
        <button type="button" data-theme-set="dark"><%= t('theme.dark') %></button>
        <button type="button" data-theme-set="colorful"><%= t('theme.colorful') %></button>
      </div>
      <div class="social-icons">
        <% if (socialLinks && socialLinks.length) { %>
          <% socialLinks.forEach(function(s) { %>
            <%- include('social-link', { link: s }) %>
          <% }); %>
        <% } else { %>
          <% if (settings.telegramUrl) { %>
            <%- include('social-link', { link: { platform: 'تلگرام', url: settings.telegramUrl, icon: 'TG' } }) %>
          <% } %>
          <% if (settings.instagramUrl) { %>
            <%- include('social-link', { link: { platform: 'اینستاگرام', url: settings.instagramUrl, icon: 'IG' } }) %>
          <% } %>
          <% if (settings.youtubeUrl) { %>
            <%- include('social-link', { link: { platform: 'یوتیوب', url: settings.youtubeUrl, icon: 'YT' } }) %>
          <% } %>
        <% } %>
      </div>
      <% if (isLoggedIn) { %>
        <a href="/wallet" class="btn btn-sm btn-outline" title="<%= t('nav.wallet') %>">💰</a>
        <% if (user.role === 'ADMIN' || user.role === 'FINANCE_ADMIN' || user.role === 'CONTENT_ADMIN' || user.role === 'SUPPORT_ADMIN') { %>
          <a href="/admin" class="btn btn-sm btn-outline"><%= t('nav.admin') %></a>
        <% } %>
        <% if (user.role === 'TEACHER') { %>
          <a href="/teacher" class="btn btn-sm btn-outline"><%= t('nav.teacherPanel') %></a>
        <% } %>
        <a href="/logout" class="btn btn-sm btn-outline"><%= t('nav.logout') %></a>
      <% } else { %>
        <a href="/login" class="btn btn-sm btn-outline"><%= t('nav.login') %></a>
        <a href="/signup" class="btn btn-sm btn-primary"><%= t('nav.signup') %></a>
      <% } %>
    </div>
  </div>
</header>
