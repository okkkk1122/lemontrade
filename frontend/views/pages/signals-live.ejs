<%- include('../partials/layout-start') %>
<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem">
  <h1>سیگنال‌های زنده</h1>
  <div>
    <span id="signals-poll" data-seconds="<%= pollSeconds %>">بروزرسانی هر <%= pollSeconds %> ثانیه</span>
    <button type="button" id="signal-sound-toggle" class="btn btn-sm btn-outline">🔕</button>
  </div>
</div>
<% if (activeSubscription) { %><p class="alert alert-success">اشتراک تا <%= new Date(activeSubscription.endDate).toLocaleDateString('fa-IR') %> فعال است</p><% } %>
<form method="get" class="card" style="margin:1rem 0;display:flex;gap:0.5rem;flex-wrap:wrap">
  <input class="form-control" name="pair" placeholder="جفت‌ارز" value="<%= typeof query !== 'undefined' ? query.pair : '' %>" style="max-width:140px" />
  <select class="form-control" name="timeframe" style="max-width:120px">
    <option value="">تایم‌فریم</option>
    <% ['1m','5m','15m','30m','1h','4h','1d'].forEach(tf => { %>
      <option value="<%= tf %>" <%= query && query.timeframe === tf ? 'selected' : '' %>><%= tf %></option>
    <% }); %>
  </select>
  <button class="btn btn-primary btn-sm">فیلتر</button>
</form>
<div class="signals-table-desktop table-wrap">
  <table><thead><tr><th>جفت</th><th>ورود</th><th>SL</th><th>TP1</th><th></th></tr></thead>
  <tbody id="signals-tbody">
    <% signals.forEach(s => { %>
      <tr>
        <td><% if (s.isNew) { %><span class="badge badge-new">جدید</span><% } %> <%= s.pairSymbol %> <%= s.tradeType %></td>
        <td><%= s.entryPrice %></td><td><%= s.stopLoss %></td><td><%= s.takeProfit1 || '-' %></td>
        <td><a href="/signals/<%= s.id %>">📷 جزئیات</a> · <%= s.timeAgo %></td>
      </tr>
    <% }) %>
  </tbody></table>
</div>
<% signals.forEach(s => { %>
  <div class="signal-card-mobile card" style="margin-bottom:0.75rem">
    <strong><%= s.pairSymbol %></strong> — <%= s.teacherName %>
    <p>ورود <%= s.entryPrice %> | SL <%= s.stopLoss %></p>
    <a href="/signals/<%= s.id %>" class="btn btn-sm btn-primary">جزئیات</a>
  </div>
<% }) %>
<%- include('../partials/layout-end') %>
