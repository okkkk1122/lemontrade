<%- include('../partials/layout-start') %>
<div class="auth-page">
  <div class="card auth-card">
    <% if (typeof sent !== 'undefined' && sent) { %>
      <h1>ارسال شد</h1>
      <p>لینک بازنشانی به ایمیل شما ارسال شد.</p>
      <a href="/login" class="btn btn-primary" style="margin-top:1rem">بازگشت به ورود</a>
    <% } else { %>
      <h1>فراموشی رمز</h1>
      <form method="post">
      <%- include('../partials/csrf-field') %><div class="form-group"><label>ایمیل</label><input class="form-control" type="email" name="email" required /></div>
      <button class="btn btn-primary" style="width:100%">ارسال لینک</button></form>
      <p style="margin-top:1rem;text-align:center"><a href="/login">بازگشت</a></p>
    <% } %>
  </div>
</div>
<%- include('../partials/layout-end') %>
