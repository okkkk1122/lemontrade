<%- include('../partials/layout-start') %>
<h1><%= t('pages.packages') %></h1>
<div style="margin:1rem 0;display:flex;gap:0.5rem;flex-wrap:wrap">
  <a href="/packages" class="btn btn-sm <%= !query || !query.category ? 'btn-primary' : 'btn-outline' %>"><%= t('packages.all') %></a>
  <% categories.forEach(c => { %><a href="/packages?category=<%= c.slug %>" class="btn btn-sm <%= query && query.category === c.slug ? 'btn-primary' : 'btn-outline' %>"><%= c.name %></a><% }) %>
</div>
<div class="grid-3">
  <% packages.forEach(p => { %>
    <div class="card">
      <img src="<%= p.coverImageUrl || '/images/package-cover.svg' %>" alt="<%= p.title %>" class="package-card-cover" loading="lazy" />
      <h3><%= p.title %></h3>
      <p style="color:var(--text-muted);margin:0.5rem 0"><%= p.shortDesc %></p>
      <p><%= formatToman(p.finalPrice) %><% if (p.finalPrice < p.price) { %> <s style="color:var(--text-muted)"><%= formatToman(p.price) %></s><% } %></p>
      <a href="/packages/<%= p.slug %>" class="btn btn-outline btn-sm"><%= t('packages.details') %></a>
      <% if (isLoggedIn) { %><form method="post" action="/cart/add" style="margin-top:0.5rem">
      <%- include('../partials/csrf-field') %><input type="hidden" name="packageId" value="<%= p.id %>" /><button class="btn btn-primary btn-sm"><%= t('packages.addToCart') %></button></form><% } %>
    </div>
  <% }) %>
</div>
<%- include('../partials/layout-end') %>
