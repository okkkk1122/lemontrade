<%- include('../partials/layout-start') %>
<link rel="stylesheet" href="/css/teacher-panel.css" />
<% if (typeof created !== 'undefined' && created) { %><div class="alert alert-success">✓ سیگنال با موفقیت ثبت شد و برای مشترکین اعلان ارسال شد.</div><% } %>
<% if (typeof updated !== 'undefined' && updated) { %><div class="alert alert-success">✓ سیگنال به‌روزرسانی شد.</div><% } %>
<% if (typeof error !== 'undefined' && error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<div class="teacher-hero">
  <div>
    <h1>سلام استاد <%= user.fullName %>!</h1>
    <p class="text-muted">امتیاز <%= teacher.rating.toFixed(1) %> · موفقیت <%= teacher.successRate %>%</p>
  </div>
  <button type="button" class="btn btn-primary" id="toggle-signal-form">+ ثبت سیگنال زنده</button>
</div>

<div class="grid-4 teacher-stats">
  <div class="card"><strong><%= teacher._count.signals %></strong><span>کل سیگنال‌ها</span></div>
  <div class="card"><strong><%= monthCount %></strong><span>این ماه</span></div>
  <div class="card"><strong><%= teacher.successRate %>%</strong><span>نرخ موفقیت</span></div>
  <div class="card"><strong><%= reports %></strong><span>گزارش اشتباه</span></div>
</div>

<form id="new-signal-form" method="post" action="/teacher/signals" class="card teacher-signal-form" hidden>
      <%- include('../partials/csrf-field') %>
  <h2>ثبت سیگنال زنده جدید</h2>
  <div class="form-grid-2">
    <div>
      <label>جفت‌ارز</label>
      <select class="form-control" name="pairSymbol" id="pairSymbol" required>
        <option value="">انتخاب کنید</option>
        <% currencyPairs.forEach(p => { %>
          <option value="<%= p.symbol %>"><%= p.symbol %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label>تایم‌فریم</label>
      <select class="form-control" name="timeframe" required>
        <% timeframes.forEach(tf => { %><option value="<%= tf %>"><%= tf %></option><% }); %>
      </select>
    </div>
    <div>
      <label>نوع معامله</label>
      <select class="form-control" name="tradeType" id="tradeType" required>
        <option value="BUY">خرید (BUY)</option>
        <option value="SELL">فروش (SELL)</option>
      </select>
    </div>
    <div>
      <label>قیمت ورود</label>
      <input class="form-control" name="entryPrice" id="entryPrice" type="number" step="any" required />
    </div>
    <div>
      <label>حد ضرر (SL)</label>
      <input class="form-control" name="stopLoss" id="stopLoss" type="number" step="any" required />
    </div>
    <div>
      <label>حد سود ۱ (TP1)</label>
      <input class="form-control" name="takeProfit1" id="takeProfit1" type="number" step="any" />
    </div>
    <div>
      <label>حد سود ۲ (TP2)</label>
      <input class="form-control" name="takeProfit2" id="takeProfit2" type="number" step="any" />
    </div>
    <div>
      <label>نسبت ریسک به ریوارد (پیش‌نمایش)</label>
      <input class="form-control" id="rrPreview" readonly placeholder="—" />
    </div>
  </div>
  <label>تحلیل و توضیحات</label>
  <textarea class="form-control" name="analysis" rows="4" placeholder="دلیل ورود، سناریو، نکات مدیریت سرمایه..."></textarea>
  <label>تصویر چارت (اختیاری — در صورت خالی بودن از لوگو استفاده می‌شود)</label>
  <input type="file" name="chart" accept="image/jpeg,image/png,image/webp" />
  <p class="text-muted" style="font-size:0.85rem">فرمت: JPG, PNG, WebP — حداکثر ۵ مگابایت</p>
  <div style="display:flex;gap:0.5rem;margin-top:1rem">
    <button type="submit" class="btn btn-primary">انتشار سیگنال زنده</button>
    <button type="button" class="btn btn-outline" id="cancel-signal-form">انصراف</button>
  </div>
</form>

<div class="table-wrap" style="margin-top:2rem">
  <h2>سیگنال‌های اخیر شما</h2>
  <table class="teacher-table">
    <thead>
      <tr><th>جفت</th><th>نوع</th><th>ورود</th><th>وضعیت</th><th>بازدید</th><th>عملیات</th></tr>
    </thead>
    <tbody>
      <% if (!signals.length) { %>
        <tr><td colspan="6" class="text-muted">هنوز سیگنالی ثبت نکرده‌اید.</td></tr>
      <% } %>
      <% signals.forEach(s => {
        const canEdit = s.status === 'ACTIVE' && (Date.now() - new Date(s.createdAt).getTime() < 3600000);
      %>
        <tr>
          <td><%= s.pairSymbol %> <small><%= s.timeframe %></small></td>
          <td><%= s.tradeType %></td>
          <td><%= s.entryPrice %></td>
          <td><span class="badge <%= s.status === 'ACTIVE' ? 'badge-new' : '' %>"><%= s.status %></span></td>
          <td><%= s.viewCount %></td>
          <td class="teacher-actions">
            <a href="/signals/<%= s.id %>">مشاهده</a>
            <% if (canEdit) { %><a href="/teacher/signals/<%= s.id %>/edit">ویرایش</a><% } %>
            <% if (s.status === 'ACTIVE') { %>
              <form method="post" action="/teacher/signals/<%= s.id %>/close" style="display:inline" onsubmit="return confirm('بستن سیگنال؟')">
                <%- include('../partials/csrf-field') %>
                <button type="submit" class="link-btn">بستن</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
(function () {
  const form = document.getElementById('new-signal-form');
  const toggle = document.getElementById('toggle-signal-form');
  const cancel = document.getElementById('cancel-signal-form');
  const rr = document.getElementById('rrPreview');
  function calcRR() {
    const entry = parseFloat(document.getElementById('entryPrice').value);
    const sl = parseFloat(document.getElementById('stopLoss').value);
    const tp = parseFloat(document.getElementById('takeProfit1').value);
    if (!entry || !sl || !tp) { rr.value = '—'; return; }
    const risk = Math.abs(entry - sl);
    const reward = Math.abs(tp - entry);
    rr.value = risk ? '1 : ' + (reward / risk).toFixed(2) : '—';
  }
  ['entryPrice', 'stopLoss', 'takeProfit1'].forEach((id) => {
    document.getElementById(id)?.addEventListener('input', calcRR);
  });
  toggle?.addEventListener('click', () => { form.hidden = false; form.scrollIntoView({ behavior: 'smooth' }); });
  cancel?.addEventListener('click', () => { form.hidden = true; });
  form?.addEventListener('submit', () => {
    const file = form.querySelector('input[name="chart"]');
    if (file?.files?.length) form.enctype = 'multipart/form-data';
    else form.removeAttribute('enctype');
  });
})();
</script>
<%- include('../partials/layout-end') %>
