<%- include('../partials/layout-start') %>
<section class="hero-slider">
  <% if (sliders && sliders.length) { sliders.forEach((s, i) => { %>
    <div class="slide <%= i === 0 ? 'active' : '' %>" style="background-image:url('<%= s.imageUrl || '/images/hero-trading.svg' %>')">
      <div class="slide-overlay"></div>
      <div class="slide-content">
        <h2><%= s.title %></h2>
        <% if (s.subtitle) { %><p><%= s.subtitle %></p><% } %>
        <% if (s.buttonLink) { %><a href="<%= s.buttonLink %>" class="btn btn-primary" style="margin-top:1rem"><%= s.buttonText || t('common.more') %></a><% } %>
      </div>
    </div>
  <% }) } else { %>
    <div class="slide active" style="background-image:url('/images/hero-trading.svg')">
      <div class="slide-overlay"></div>
      <div class="slide-content">
        <h2><%= t('home.heroTitle') %></h2>
        <p><%= t('home.heroSubtitle') %></p>
        <a href="/signup" class="btn btn-primary" style="margin-top:1rem"><%= t('home.heroCta') %></a>
      </div>
    </div>
  <% } %>
</section>

<h2 class="section-title"><%= t('home.services') %></h2>
<div class="grid-3">
  <% (cards && cards.length ? cards : []).forEach(c => { %>
    <div class="card">
      <% if (c.imageUrl) { %><img src="<%= c.imageUrl %>" alt="<%= c.title %>" class="card-media" loading="lazy" /><% } else if (c.icon) { %><div style="font-size:2.5rem;margin-bottom:0.5rem"><%= c.icon %></div><% } %>
      <h3><%= c.title %></h3>
      <p style="color:var(--text-muted);margin:0.75rem 0"><%= c.description %></p>
      <a href="<%= c.buttonLink %>" class="btn btn-secondary btn-sm"><%= c.buttonText || t('common.continue') %></a>
    </div>
  <% }) %>
</div>

<h2 class="section-title"><%= t('home.sampleSignals') %></h2>
<div class="grid-3">
  <% (sampleSignals || []).forEach(s => { %>
    <div class="card">
      <strong><%= s.pairSymbol %></strong>
      <p><%= t('home.entry') %>: <%= s.entryPrice %> | SL: <%= s.stopLoss %></p>
      <p><%= t('home.teacher') %>: <%= s.teacher?.user?.fullName || '—' %> ⭐ <%= s.teacher?.rating || 4.5 %></p>
      <a href="/signals/<%= s.id %>" class="btn btn-outline btn-sm"><%= t('home.viewDetails') %></a>
    </div>
  <% }) %>
</div>

<h2 class="section-title"><%= t('home.topTeachers') %></h2>
<div class="grid-4">
  <% (topTeachers || []).forEach(tchr => { %>
    <div class="card" style="text-align:center">
      <img src="/images/team-member.svg" alt="" class="team-photo" width="96" height="96" />
      <h4><%= tchr.user.fullName %></h4>
      <p>⭐ <%= tchr.rating.toFixed(1) %> | <%= tchr._count?.signals || 0 %> <%= t('home.signalsCount') %></p>
    </div>
  <% }) %>
</div>

<h2 class="section-title"><%= t('home.stats') %></h2>
<div class="grid-4" data-counters>
  <div class="card"><div class="stat-counter" data-target="<%= stats.users %>">0</div><p><%= t('home.activeUsers') %></p></div>
  <div class="card"><div class="stat-counter" data-target="<%= stats.signals %>">0</div><p><%= t('home.successfulSignals') %></p></div>
  <div class="card"><div class="stat-counter" data-target="<%= stats.profitPercent %>">0</div><p><%= t('home.avgProfit') %></p></div>
  <div class="card"><div class="stat-counter" data-target="<%= stats.sessions %>">0</div><p><%= t('home.sessionsHeld') %></p></div>
</div>
<script>
document.querySelectorAll('[data-target]').forEach(el => {
  const t = +el.dataset.target; let c = 0;
  const step = Math.ceil(t / 40);
  const loc = '<%= dateLocale %>';
  const iv = setInterval(() => { c += step; if (c >= t) { c = t; clearInterval(iv); } el.textContent = c.toLocaleString(loc); }, 30);
});
</script>

<h2 class="section-title"><%= t('home.upcomingSessions') %></h2>
<% (upcomingSessions || []).forEach(s => { %>
  <div class="card" style="margin-bottom:0.75rem">
    <strong><%= s.title %></strong> — <%= s.teacher?.user?.fullName %>
    <span style="color:var(--text-muted)"><%= new Date(s.startAt).toLocaleString(dateLocale) %></span>
  </div>
<% }) %>
<a href="/sessions" class="btn btn-outline"><%= t('home.viewAllSessions') %></a>

<h2 class="section-title"><%= t('home.faq') %></h2>
<% (faqs || []).forEach(f => { %>
  <details class="card" style="margin-bottom:0.5rem"><summary><%= f.question %></summary><p style="margin-top:0.5rem;color:var(--text-muted)"><%= f.answer %></p></details>
<% }) %>
<a href="/faq" class="btn btn-outline" style="margin-top:1rem"><%= t('home.viewAllFaq') %></a>
<%- include('../partials/layout-end') %>
