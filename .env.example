# lemontrade (لیموترید) — copy to .env for local development
PORT=3010
NODE_ENV=development
DATABASE_URL=postgresql://limootrade:limootrade_secret@localhost:5432/limootrade
SESSION_SECRET=your-super-secret-session-key-min-32-chars
APP_URL=http://localhost:3010
# false برای localhost بدون HTTPS (Docker محلی)
COOKIE_SECURE=false

# Zarinpal
ZARINPAL_MERCHANT=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=true

# SMTP (email verification, notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lemontrade.com

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Default admin (seed)
ADMIN_EMAIL=admin@lemontrade.com
ADMIN_PASSWORD=Admin@12345
