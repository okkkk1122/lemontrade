# Production — copy to .env and set strong secrets before deploy

PORT=3010
NODE_ENV=production
DOMAIN=your-domain.com
APP_URL=https://your-domain.com
COOKIE_SECURE=true
DISABLE_RATE_LIMIT=false

POSTGRES_PASSWORD=CHANGE_ME_STRONG
DATABASE_URL=postgresql://limootrade:CHANGE_ME_STRONG@postgres:5432/limootrade
SESSION_SECRET=generate-a-random-string-at-least-32-characters

ZARINPAL_MERCHANT=your-real-merchant-id
ZARINPAL_SANDBOX=false

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lemontrade.com

ADMIN_EMAIL=admin@lemontrade.com
ADMIN_PASSWORD=change-after-first-login
